# Media Platform — Caddy Reverse Proxy
# Routes: /api/v1/* → API (versioned), /api/events → SSE, /* → Frontend SPA
{
	# Use HTTP locally; override with HTTPS domain in production
	auto_https off
}

(security_headers) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}

:80 {
	import security_headers

	encode gzip zstd

	# SSE endpoint — disable buffering for real-time streaming
	handle /api/events {
		reverse_proxy media-platform-api:8080 {
			flush_interval -1
			transport http {
				read_timeout 0
			}
		}
	}

	# Legacy SSE redirect (/events → /api/events)
	handle /events {
		reverse_proxy media-platform-api:8080
	}

	# All API routes (versioned /api/v1/* and unversioned /api/events)
	handle /api/* {
		reverse_proxy media-platform-api:8080
	}

	# Health endpoints (no auth required)
	handle /health/* {
		reverse_proxy media-platform-api:8080
	}
	handle /health {
		reverse_proxy media-platform-api:8080
	}

	# Metrics — restrict to internal/private networks
	@internal remote_ip 192.168.0.0/16 172.16.0.0/12 10.0.0.0/8
	handle /metrics {
		reverse_proxy @internal media-platform-api:8080
		respond 403
	}

	# OpenAPI docs
	handle /openapi/* {
		reverse_proxy media-platform-api:8080
	}
	handle /scalar/* {
		reverse_proxy media-platform-api:8080
	}

	# Frontend SPA (catch-all)
	handle {
		reverse_proxy media-platform-web:80
	}
}
