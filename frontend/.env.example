# API
VITE_API_BASE_URL=/api/v1
VITE_API_EVENTS_URL=/api/events

# Auth bypass for local development (no Keycloak needed)
VITE_AUTH_BYPASS=true

# Keycloak (only used when VITE_AUTH_BYPASS is not "true")
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=media-platform
VITE_KEYCLOAK_CLIENT_ID=media-frontend

# Worker key (TV kiosk SSE auth)
VITE_WORKER_KEY=
